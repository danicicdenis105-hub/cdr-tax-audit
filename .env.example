# CDR Tax Analyzer — Environment Configuration
# Copy this file to .env and fill in the values

# ============================================================
# Database Configuration
# ============================================================

# SQLite (Development)
DATABASE_URL="file:./dev.db"

# PostgreSQL (Production)
# DATABASE_URL="postgresql://user:password@host:5432/cdr_tax_audit?schema=public"

# ============================================================
# Authentication
# ============================================================

# JWT secret — MUST be changed in production (use: openssl rand -base64 32)
NEXTAUTH_SECRET="change-this-to-a-random-secret-in-production"

# Application URL
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# Optional: Production Settings
# ============================================================

# NODE_ENV=production
# PORT=3000
