// PostgreSQL schema for production deployment
// To switch: update DATABASE_URL in .env, copy this file to schema.prisma, run prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("analyst")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TelecomCompany {
  id              String       @id @default(cuid())
  name            String
  licenseNumber   String       @unique
  region          String
  status          String       @default("active")
  contactEmail    String
  contactPhone    String       @default("")
  taxId           String
  numberPrefixes  String       @default("")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  cdrRecords      CDRRecord[]
  uploads         CDRUpload[]
  reports         Report[]
  salesReports    SalesReport[]
  ratePlans       RatePlan[]
}

model CDRRecord {
  id                  String         @id @default(cuid())
  companyId           String
  company             TelecomCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  callType            String
  duration            Int?
  billedDuration      Int?
  dataUsageMB         Float?
  timestamp           DateTime
  originNumber        String
  destinationNumber   String
  calculatedRevenue   Float
  amountHT            Float?
  taxTictech          Float?
  destinationOperator String?
  recordHash          String?
  billingType         String?
  uploadId            String?
  upload              CDRUpload?     @relation(fields: [uploadId], references: [id])
  createdAt           DateTime       @default(now())

  @@index([companyId])
  @@index([callType])
  @@index([timestamp])
  @@index([uploadId])
  @@index([recordHash])
}

model CDRUpload {
  id               String         @id @default(cuid())
  companyId        String
  company          TelecomCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fileName         String
  fileSize         Int
  recordCount      Int            @default(0)
  status           String         @default("processing")
  errorMessage     String?
  fileHash         String?
  originalFileName String?
  uploadedById     String?
  acceptedCount    Int            @default(0)
  rejectedCount    Int            @default(0)
  warningCount     Int            @default(0)
  validationReport String?        @db.Text
  uploadedAt       DateTime       @default(now())
  processedAt      DateTime?
  records          CDRRecord[]

  @@index([companyId])
}

model SalesReport {
  id                  String         @id @default(cuid())
  companyId           String
  company             TelecomCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  period              String
  reportedRevenue     Float
  voiceRevenue        Float          @default(0)
  smsRevenue          Float          @default(0)
  dataRevenue         Float          @default(0)
  intlRevenue         Float          @default(0)
  rechargeRevenue     Float          @default(0)
  subscriptionRevenue Float          @default(0)
  roamingRevenue      Float          @default(0)
  submittedAt         DateTime       @default(now())

  @@unique([companyId, period])
  @@index([companyId])
  @@index([period])
}

model Report {
  id               String          @id @default(cuid())
  title            String
  type             String
  period           String
  status           String          @default("draft")
  companyId        String?
  company          TelecomCompany? @relation(fields: [companyId], references: [id])
  companyCount     Int             @default(0)
  estimatedLeakage Float           @default(0)
  fileSize         String          @default("0 KB")
  parameters       String?         @db.Text
  version          Int             @default(1)
  generatedBy      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([companyId])
  @@index([type])
}

model Settings {
  id                     String  @id @default("global")
  taxTTC                 Float   @default(26)
  tictechRate            Float   @default(7)
  discrepancyThreshold   Float   @default(5)
  criticalThreshold      Float   @default(20)
  voiceRate              Float   @default(25)
  smsRate                Float   @default(15)
  dataRate               Float   @default(0.5)
  emailAlerts            Boolean @default(true)
  weeklyReports          Boolean @default(true)
  uploadNotifications    Boolean @default(false)
  reportFormat           String  @default("pdf")
  dateFormat             String  @default("dmy")
  currency               String  @default("xaf")
}

model TaxPeriod {
  id          String    @id @default(cuid())
  name        String
  tvaRate     Float
  tictechRate Float
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  @@index([startDate])
}

model RatePlan {
  id          String         @id @default(cuid())
  companyId   String
  company     TelecomCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceType String
  rate        Float
  unit        String
  startDate   DateTime
  endDate     DateTime?
  createdAt   DateTime       @default(now())

  @@unique([companyId, serviceType, startDate])
  @@index([companyId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}
